# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real secrets.

# Claude auth (DM engine): by default Chronicle uses your Claude SUBSCRIPTION,
# via the login stored under ~/.claude (run `claude` once to log in — see
# SETUP.md). Leave ANTHROPIC_API_KEY UNSET to keep subscription billing.
# Setting ANTHROPIC_API_KEY switches the engine to the per-token Claude API
# instead. (Subscription use of the Agent SDK is undocumented — see ADR-0017.)
# ANTHROPIC_API_KEY=

# Optional. Which network interface to bind to.
#   127.0.0.1 (default)  — this machine only, not reachable from the LAN.
#   <your LAN IP>        — reachable from other devices on your home network.
#   0.0.0.0               — all interfaces (still firewalled by ufw per SETUP.md).
HOST=127.0.0.1

# Optional. Port the HTTP API (and mobile UI) listens on. Default: 4317.
PORT=4317

# ─────────────────────────────────────────────────────────────────────────────
# Multi-user (ADR-0019)
# ─────────────────────────────────────────────────────────────────────────────
# Chronicle has per-user accounts. There is no shared passphrase anymore —
# each person registers a username + password in the app (open signup on your
# LAN) and logs in from any device. Password hashes and session tokens live
# under a gitignored `users/` dir.

# Bootstrap user — owns the campaigns that existed BEFORE the multi-user
# migration (test-campaign, and any real campaigns you were already playing).
# `npm run migrate:multi-user` creates this account and moves those campaigns
# under it. Pick a real password; you'll log in with these.
BOOTSTRAP_USERNAME=kris
BOOTSTRAP_PASSWORD=replace-with-a-real-password

# ─────────────────────────────────────────────────────────────────────────────
# Default settings a NEW user's account inherits (ADR-0019)
# ─────────────────────────────────────────────────────────────────────────────
# Seeded into a new account at registration; every new campaign that user
# creates starts from these (and each game can override them per-game).
# All optional — anything unset falls back to the app's own defaults.
#
# DEFAULT_MODEL: claude-sonnet-5 | claude-opus-4-8 | claude-haiku-4-5 |
#                grok-build | grok-composer-2.5-fast
# DEFAULT_PROVIDER: claude | grok   (a DEFAULT_MODEL must belong to it)
# DEFAULT_CONTENT_INTENSITY: standard | low
# DEFAULT_RESPONSE_LENGTH: concise | standard | detailed
# DEFAULT_TONE_WHIMSY: a number 0.0–1.0
# The DEFAULT_GENERATE_IMAGES / _AUTO_ROLL_DICE / _AUTO_ILLUSTRATE flags are
# literally "true" or "false".
# DEFAULT_MODEL=claude-sonnet-5
# DEFAULT_PROVIDER=claude
# DEFAULT_ART_STYLE=oil painting
# DEFAULT_WORLD_SETTING=
# DEFAULT_TONE_WHIMSY=0.5
# DEFAULT_CONTENT_INTENSITY=standard
# DEFAULT_RESPONSE_LENGTH=detailed
# DEFAULT_GENERATE_IMAGES=false
# DEFAULT_AUTO_ROLL_DICE=true
# DEFAULT_AUTO_ILLUSTRATE=false

# ─────────────────────────────────────────────────────────────────────────────
# Music (ADR-0020) — optional, off by default
# ─────────────────────────────────────────────────────────────────────────────
# Players can enable background music in Settings and choose a source:
#   local     — files you drop into the `music/` folder (mp3/wav/ogg/flac/m4a,
#               sub-foldered however you like). `music/` is gitignored.
#   navidrome — a playlist streamed from a Navidrome server on your LAN, proxied
#               through this server (the browser never sees Navidrome creds).
#
# DEFAULT_MUSIC_ENABLED / DEFAULT_MUSIC_SOURCE seed a new account (each user can
# then override in Settings). NAVIDROME_* are the Navidrome connection; USER and
# PASSWORD stay server-side (never overridable from the client). A user may
# override the URL and playlist in their own settings.
# DEFAULT_MUSIC_ENABLED=false
# DEFAULT_MUSIC_SOURCE=local
# NAVIDROME_URL=http://192.168.1.214:4533
# NAVIDROME_USER=your-navidrome-username
# NAVIDROME_PASSWORD=your-navidrome-password
# NAVIDROME_PLAYLIST=chronicle

# Optional. Image generation (scene art / portraits) is done by the Grok
# Build "grok" CLI, which the server shells out to on this host — it is NOT
# required to play. Easiest setup is to install and log in to the grok CLI
# interactively (its auth lives under ~/.grok); if you prefer key-based auth,
# set the CLI's expected key here (e.g. XAI_API_KEY). See SETUP.md.
# XAI_API_KEY=
