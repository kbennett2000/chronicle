# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real secrets.

# Claude auth (DM engine): by default Chronicle uses your Claude SUBSCRIPTION,
# via the login stored under ~/.claude (run `claude` once to log in — see
# SETUP.md). Leave ANTHROPIC_API_KEY UNSET to keep subscription billing.
# Setting ANTHROPIC_API_KEY switches the engine to the per-token Claude API
# instead. (Subscription use of the Agent SDK is undocumented — see ADR-0017.)
# ANTHROPIC_API_KEY=

# Required. Shared passphrase the server requires on every API request
# (sent by the mobile UI as the X-Chronicle-Token header). Pick something
# long and hard to guess — anyone with this value can play your campaigns.
CHRONICLE_SHARED_SECRET=replace-with-a-long-random-passphrase

# Optional. Which network interface to bind to.
#   127.0.0.1 (default)  — this machine only, not reachable from the LAN.
#   <your LAN IP>        — reachable from other devices on your home network.
#   0.0.0.0               — all interfaces (still firewalled by ufw per SETUP.md).
HOST=127.0.0.1

# Optional. Port the HTTP API (and mobile UI) listens on. Default: 4317.
PORT=4317

# Optional. Image generation (scene art / portraits) is done by the Grok
# Build "grok" CLI, which the server shells out to on this host — it is NOT
# required to play. Easiest setup is to install and log in to the grok CLI
# interactively (its auth lives under ~/.grok); if you prefer key-based auth,
# set the CLI's expected key here (e.g. XAI_API_KEY). See SETUP.md step 7.
# XAI_API_KEY=
