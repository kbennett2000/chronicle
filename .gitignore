node_modules/
dist/
*.log
npm-debug.log*

# Local Claude Code settings (machine-specific)
.claude/settings.local.json

# Never commit auth/keys
.env
.env.*
!.env.example
.grok/
.credentials.json

# Agent SDK session pointers (local runtime state, not source)
**/.session-id

# Campaign data (ADR-0005): real player campaigns never enter git.
# test-campaign is a deliberately tracked dev/validation fixture, and
# _registry is shared cross-campaign infra (genre-neutral seed-table
# dedup log, not player data) — both are explicit exceptions.
campaigns/*
!campaigns/test-campaign
!campaigns/test-campaign/**
!campaigns/_registry
!campaigns/_registry/**

# Re-exclude runtime state even inside the tracked test-campaign exception
campaigns/test-campaign/.session-id
campaigns/test-campaign/**/.session-id
