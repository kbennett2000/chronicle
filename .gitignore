node_modules/
dist/
*.log
npm-debug.log*

# Playwright output (web/)
test-results/
playwright-report/
blob-report/

# Local Claude Code settings (machine-specific)
.claude/settings.local.json

# Never commit auth/keys
.env
.env.*
!.env.example
.grok/
.credentials.json

# User accounts (ADR-0019): password hashes, session tokens, and per-user
# default settings live here — never enters git.
users/

# Music (ADR-0020): the player's own local media — never enters git.
music/

# Agent SDK session pointers (local runtime state, not source)
**/.session-id

# Campaign data (ADR-0005): real player campaigns never enter git.
# _registry is shared cross-campaign infra (genre-neutral seed-table dedup log,
# not player data). test-campaign is a deliberately tracked dev/validation
# fixture; after the ADR-0019 multi-user migration it is owned by the bootstrap
# user "kris" at campaigns/kris/test-campaign — the one nested path we un-ignore.
campaigns/*
!campaigns/_registry
!campaigns/_registry/**
!campaigns/kris/
campaigns/kris/*
!campaigns/kris/test-campaign
!campaigns/kris/test-campaign/**

# Re-exclude runtime state even inside the tracked test-campaign exception
campaigns/kris/test-campaign/.session-id
campaigns/kris/test-campaign/**/.session-id
# Issue #68 (ADR-0016): per-turn state snapshots are runtime rewind state, not
# source — never commit them, not even under the tracked test-campaign fixture.
campaigns/kris/test-campaign/session-log/snapshots/
campaigns/kris/test-campaign/**/snapshots/
